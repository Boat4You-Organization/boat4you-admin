    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "file-saver": "^2.0.5",
    "i18next": "^25.7.3",
    "lodash.debounce": "^4.0.8",
    "react": "^19.2.3",
