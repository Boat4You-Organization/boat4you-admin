    "sass": "^1.97.1",
    "validator": "^13.15.26",
    "valtio": "^2.2.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint:base": "eslint --ext .ts,.tsx src/",
    "lint:styles": "stylelint '**/*.scss' --fix",
    "lint": "pretty-quick && yarn lint:base --fix --cache --cache-location=./node_modules/.cache/ && yarn lint:styles",
    "upgrade": "yarn upgrade",
    "i18next-resources-for-ts": "i18next-resources-for-ts interface -i ./src/locales/en -o ./src/@types/resources.d.ts"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/file-saver": "^2.0.7",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
